{
  "name": "TimetableGenerator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Timetable Generator Application",
  "author": "ELMAHDI JAOUALI",
  "scripts": {
    "dev": "npm run build:electron-files && vite",
    "dev:web": "vite --config vite.config.web.ts",
    "dev:frontend": "vite",
    "dev:backend": "cd ../backend && npm run dev",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build --config vite.config.web.ts",
    "build:electron-files": "tsc -p tsconfig.node.json && tsc -p tsconfig.electron.json",
    "build:electron": "npm run build && npm run build:electron-files && electron-builder",
    "build:linux": "npm run build && npm run build:electron-files && electron-builder --linux",
    "build:win": "npm run build && npm run build:electron-files && electron-builder --win",
    "build:mac": "npm run build && npm run build:electron-files && electron-builder --mac",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@tailwindcss/vite": "^4.1.2",
    "axios": "^1.10.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.4.1"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.timetable.generator",
    "productName": "Timetable Generator",
    "files": [
      "dist/",
      "dist-electron/",
      "backend/",
      "electron/",
      "node_modules/",
      "package.json"
    ],
    "extraResources": [
      "backend/config/",
      "backend/uploads/"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}